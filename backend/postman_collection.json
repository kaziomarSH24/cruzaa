                                "homepage"
                            ]
                        }
                    }
                },
                {
                    "name": "Create/Update Content",
                    "request": {
                        "method": "POST",
                        "body": {
                            "mode": "formdata",
                            "formdata": [
                                {
                                    "key": "content_key",
                                    "value": "hero_title",
                                    "type": "text"
                                },
                                {
                                    "key": "content_type",
                                    "value": "text",
                                    "type": "text"
                                },
                                {
                                    "key": "content_value",
                                    "value": "Welcome to Cruzaa",
                                    "type": "text"
                                },
                                {
                                    "key": "content_group",
                                    "value": "homepage",
                                    "type": "text"
                                }
                            ]
                        },
                        "url": {
                            "raw": "{{base_url}}/content",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "content"
                            ]
                        }
                    }
                }
            ]
        },
        {
            "name": "Settings",
