                        "auth": {
                            "type": "noauth"
                        },
                        "method": "GET",
                        "url": {
                            "raw": "{{base_url}}/navigation?location=header",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "navigation"
                            ],
                            "query": [
                                {
                                    "key": "location",
                                    "value": "header"
                                }
                            ]
                        }
                    }
                },
                {
                    "name": "Create Navigation Item",
                    "request": {
                        "method": "POST",
                        "header": [
