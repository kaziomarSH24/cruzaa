# Environment variables (DO NOT commit this file to version control)

# Database Configuration
DB_HOST=localhost
DB_NAME=cruzaa_admin
DB_USER=root
DB_PASS=

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# App Configuration
APP_ENV=development
APP_DEBUG=true
APP_URL=http://localhost

# SMTP Configuration (Optional - Can be set via admin panel)
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_ENCRYPTION=tls
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=

# Stripe Configuration (Optional - Can be set via admin panel)
STRIPE_MODE=test
STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Upload Configuration
MAX_FILE_SIZE=5242880
UPLOAD_PATH=/uploads/

# Session Configuration
SESSION_LIFETIME=86400
